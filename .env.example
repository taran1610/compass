# =============================================================================
# Compass — environment variables
# =============================================================================

# --- Supabase (required for auth + RAG in production) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side inserts/queries; prefer service role in production for consistent counts/list
SUPABASE_SERVICE_ROLE_KEY=

# --- AI ---
# Many flows use Anthropic (PRD, features, opportunities, insights). Embeddings often use OpenAI.
# Set at least one provider; for full RAG + chat you may need BOTH — see README.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Stripe (optional for first launch / waitlist-only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create via: npx tsx scripts/setup-stripe.ts)
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ID_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=

# Production app URL (OAuth redirects, Stripe return URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Production launch checklist (manual)
# =============================================================================
# [ ] Run SQL migrations in supabase/migrations/ on your Supabase project
# [ ] Auth → Google: enable provider; add Site URL + redirect URL:
#       https://<your-domain>/auth/callback  (and localhost for dev)
# [ ] Vercel/hosting: set all env vars above; NEXT_PUBLIC_APP_URL = production URL
# [ ] Confirm OPENAI + ANTHROPIC keys match what ingest/chat/features expect
# [ ] Stripe: only if taking payments — webhook endpoint + STRIPE_WEBHOOK_SECRET
